# Copy this file to .env.deploy on the DigitalOcean droplet.
# Do not commit the real .env.deploy file.

SERVER_NAME=example.com
PRIMARY_DOMAIN=example.com

# Generate with:
# openssl rand -hex 32
APP_SECRET=change-me

MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

HTTP_PORT=80
HTTPS_PORT=443
HTTP3_PORT=443

# Small droplet defaults. Increase only after checking memory pressure.
PHP_CPUS=0.75
PHP_MEMORY_LIMIT=384M
PHP_GO_MEMORY_LIMIT=320MiB
MYSQL_CPUS=0.50
MYSQL_MEMORY_LIMIT=384M

# Prevent Docker json logs from filling the disk.
PHP_LOG_MAX_SIZE=10m
PHP_LOG_MAX_FILE=3
MYSQL_LOG_MAX_SIZE=10m
MYSQL_LOG_MAX_FILE=3
